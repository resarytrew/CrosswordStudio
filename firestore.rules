rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isValidSlug(slug) {
      return slug is string && slug.size() >= 6 && slug.size() <= 16 && slug.matches('^[a-z0-9]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

function crosswordReadable(data) {
      return data.isPublished == true
        || data.visibility == 'link'
        || data.visibility == 'public'
        || (isSignedIn() && data.authorId == request.auth.uid);
    }

function isValidCrossword(data) {
      return data.keys().hasAll(['authorId', 'title', 'boardState', 'answersHash', 'createdAt', 'updatedAt', 'isPublished'])
        && data.authorId is string && data.authorId == request.auth.uid
        && data.title is string && data.title.size() <= 100
        && data.boardState is map
        && data.answersHash is string && data.answersHash.size() <= 64
        && data.createdAt is number && data.createdAt > 0
        && data.updatedAt is number && data.updatedAt > 0
        && data.isPublished is bool
        && (data.isTemplate == null || data.isTemplate is bool)
        && (data.slug == null || isValidSlug(data.slug))
        && (data.visibility == null || data.visibility in ['private', 'link', 'public'])
        && (data.difficulty == null || data.difficulty in ['easy', 'medium', 'hard'])
        && (data.authorDisplayName == null || (data.authorDisplayName is string && data.authorDisplayName.size() <= 120));
    }

function isValidCrosswordUpdate(data, old) {
      return data.keys().hasAll(['authorId', 'title', 'boardState', 'answersHash', 'createdAt', 'updatedAt', 'isPublished'])
        && data.authorId == old.authorId
        && data.createdAt == old.createdAt
        && data.title is string && data.title.size() <= 100
        && data.boardState is map
        && data.answersHash is string && data.answersHash.size() <= 64
        && data.updatedAt is number && data.updatedAt >= old.updatedAt
        && data.isPublished is bool
        && (data.isTemplate == null || data.isTemplate is bool)
        && (data.slug == null || isValidSlug(data.slug))
        && (data.visibility == null || data.visibility in ['private', 'link', 'public'])
        && (data.difficulty == null || data.difficulty in ['easy', 'medium', 'hard'])
        && (data.authorDisplayName == null || (data.authorDisplayName is string && data.authorDisplayName.size() <= 120));
    }

    match /crosswords/{crosswordId} {
      allow get: if true;
      allow list: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    match /shareLinks/{slug} {
      allow get: if isValidSlug(slug);
      allow list: if false;
      allow create: if isSignedIn()
        && isValidSlug(slug)
        && incoming().keys().hasOnly(['crosswordId'])
        && incoming().crosswordId is string
        && isValidId(incoming().crosswordId)
        && exists(/databases/$(database)/documents/crosswords/$(incoming().crosswordId))
        && get(/databases/$(database)/documents/crosswords/$(incoming().crosswordId)).data.authorId == request.auth.uid;
      allow delete: if isSignedIn()
        && isValidSlug(slug)
        && resource.data.crosswordId is string
        && exists(/databases/$(database)/documents/crosswords/$(resource.data.crosswordId))
        && get(/databases/$(database)/documents/crosswords/$(resource.data.crosswordId)).data.authorId == request.auth.uid;
      allow update: if false;
    }

    function isValidProgress(data) {
      return data.keys().hasAll(['userId', 'crosswordId', 'answers', 'timer', 'isCompleted', 'lastUpdated'])
        && data.userId is string && data.userId == request.auth.uid
        && data.crosswordId is string && data.crosswordId.size() <= 128
        && data.answers is string && data.answers.size() <= 200000
        && data.timer is number
        && data.isCompleted is bool
        && data.lastUpdated is number;
    }

    function isValidProgressUpdate(data, old) {
       return data.keys().hasAll(['userId', 'crosswordId', 'answers', 'timer', 'isCompleted', 'lastUpdated'])
         && data.userId == old.userId
         && data.crosswordId == old.crosswordId
         && data.answers is string && data.answers.size() <= 200000
         && data.timer is number
         && data.isCompleted is bool
         && data.lastUpdated is number && data.lastUpdated >= old.lastUpdated;
    }

    match /progress/{progressId} {
      allow get: if isValidId(progressId) && isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isValidId(progressId) && isSignedIn() && isValidProgress(incoming());
         
      allow update: if isValidId(progressId) && isSignedIn() && existing().userId == request.auth.uid && (
         incoming().diff(existing()).affectedKeys().hasOnly(['answers', 'timer', 'isCompleted', 'lastUpdated']) &&
         isValidProgressUpdate(incoming(), existing())
       );

      allow delete: if isValidId(progressId) && isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
